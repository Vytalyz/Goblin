{
  "workflow_id": "scalping_discovery_v1",
  "version": "1.0.0",
  "start_node": "reframe_question",
  "input_schema": "DiscoveryRequest",
  "output_schema": "CandidateDraft",
  "nodes": [
    {
      "id": "reframe_question",
      "kind": "agent",
      "name": "Reframe Question",
      "input_schema": "DiscoveryRequest",
      "output_schema": "ReframedQuestion",
      "config": {
        "task_name": "reframe_question",
        "system_prompt": "reframe_system.txt",
        "user_prompt": "reframe_user.txt"
      },
      "on_failure": "halt"
    },
    {
      "id": "collect_corpus_context",
      "kind": "tool",
      "name": "Collect Corpus Context",
      "input_schema": "ReframedQuestion",
      "output_schema": "CorpusDigest",
      "config": {
        "tool_name": "collect_corpus_digest"
      },
      "on_failure": "halt"
    },
    {
      "id": "scalping_analyst",
      "kind": "agent",
      "name": "Scalping Analyst",
      "input_schema": "CorpusDigest",
      "output_schema": "CandidateDraft",
      "config": {
        "task_name": "scalping_analyst",
        "system_prompt": "scalping_system.txt",
        "user_prompt": "scalping_user.txt"
      },
      "on_failure": "halt"
    },
    {
      "id": "finalize_candidate",
      "kind": "finalize",
      "name": "Finalize Candidate",
      "input_schema": "CandidateDraft",
      "output_schema": "CandidateDraft",
      "config": {
        "tool_name": "finalize_candidate"
      },
      "on_failure": "halt"
    }
  ],
  "edges": [
    {
      "source": "reframe_question",
      "target": "collect_corpus_context",
      "contract": "ReframedQuestion"
    },
    {
      "source": "collect_corpus_context",
      "target": "scalping_analyst",
      "contract": "CorpusDigest"
    },
    {
      "source": "scalping_analyst",
      "target": "finalize_candidate",
      "contract": "CandidateDraft"
    }
  ],
  "trigger": "cli:discover",
  "rollback": "discard_draft"
}
