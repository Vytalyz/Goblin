{
  "workflow_id": "strategy_discovery_router_v1",
  "version": "2.0.0",
  "start_node": "reframe_question",
  "input_schema": "DiscoveryRequest",
  "output_schema": "CandidateDraft",
  "trigger": "cli:discover",
  "rollback": "discard_draft",
  "nodes": [
    {
      "id": "reframe_question",
      "kind": "agent",
      "name": "Reframe Question",
      "input_schema": "DiscoveryRequest",
      "output_schema": "ReframedQuestion",
      "config": {
        "task_name": "reframe_question",
        "system_prompt": "reframe_system.txt",
        "user_prompt": "reframe_user.txt"
      },
      "on_failure": "halt"
    },
    {
      "id": "collect_corpus_context",
      "kind": "tool",
      "name": "Collect Corpus Context",
      "input_schema": "ReframedQuestion",
      "output_schema": "CorpusDigest",
      "config": {
        "tool_name": "collect_corpus_digest"
      },
      "on_failure": "halt"
    },
    {
      "id": "route_family",
      "kind": "router",
      "name": "Route Family",
      "input_schema": "CorpusDigest",
      "output_schema": "CorpusDigest",
      "config": {
        "tool_name": "route_strategy_family"
      },
      "on_failure": "halt"
    },
    {
      "id": "scalping_analyst",
      "kind": "agent",
      "name": "Scalping Strategist",
      "input_schema": "CorpusDigest",
      "output_schema": "CandidateDraft",
      "config": {
        "task_name": "scalping_analyst",
        "system_prompt": "scalping_system.txt",
        "user_prompt": "scalping_user.txt",
        "role_brief": "scalping-strategist.md",
        "skill_guide": "strategy-discovery.md"
      },
      "on_failure": "halt"
    },
    {
      "id": "day_trading_analyst",
      "kind": "agent",
      "name": "Day Trading Strategist",
      "input_schema": "CorpusDigest",
      "output_schema": "CandidateDraft",
      "config": {
        "task_name": "day_trading_analyst",
        "system_prompt": "day_trading_system.txt",
        "user_prompt": "day_trading_user.txt",
        "role_brief": "day-trading-strategist.md",
        "skill_guide": "strategy-discovery.md"
      },
      "on_failure": "halt"
    },
    {
      "id": "quant_critic",
      "kind": "agent",
      "name": "Quant Critic",
      "input_schema": "CandidateDraft",
      "output_schema": "CandidateDraft",
      "config": {
        "task_name": "quant_critic",
        "system_prompt": "critic_system.txt",
        "user_prompt": "critic_user.txt",
        "role_brief": "quant-critic.md",
        "skill_guide": "critic-review.md"
      },
      "on_failure": "halt"
    },
    {
      "id": "risk_critic",
      "kind": "agent",
      "name": "Risk Critic",
      "input_schema": "CandidateDraft",
      "output_schema": "CandidateDraft",
      "config": {
        "task_name": "risk_critic",
        "system_prompt": "critic_system.txt",
        "user_prompt": "critic_user.txt",
        "role_brief": "risk-critic.md",
        "skill_guide": "critic-review.md"
      },
      "on_failure": "halt"
    },
    {
      "id": "execution_realist",
      "kind": "agent",
      "name": "Execution Realist",
      "input_schema": "CandidateDraft",
      "output_schema": "CandidateDraft",
      "config": {
        "task_name": "execution_realist",
        "system_prompt": "critic_system.txt",
        "user_prompt": "critic_user.txt",
        "role_brief": "execution-realist.md",
        "skill_guide": "critic-review.md"
      },
      "on_failure": "halt"
    },
    {
      "id": "finalize_candidate",
      "kind": "finalize",
      "name": "Finalize Candidate",
      "input_schema": "CandidateDraft",
      "output_schema": "CandidateDraft",
      "config": {
        "tool_name": "finalize_candidate"
      },
      "on_failure": "halt"
    }
  ],
  "edges": [
    {
      "source": "reframe_question",
      "target": "collect_corpus_context",
      "contract": "ReframedQuestion"
    },
    {
      "source": "collect_corpus_context",
      "target": "route_family",
      "contract": "CorpusDigest"
    },
    {
      "source": "route_family",
      "target": "scalping_analyst",
      "contract": "CorpusDigest"
    },
    {
      "source": "route_family",
      "target": "day_trading_analyst",
      "contract": "CorpusDigest"
    },
    {
      "source": "scalping_analyst",
      "target": "quant_critic",
      "contract": "CandidateDraft"
    },
    {
      "source": "day_trading_analyst",
      "target": "quant_critic",
      "contract": "CandidateDraft"
    },
    {
      "source": "quant_critic",
      "target": "risk_critic",
      "contract": "CandidateDraft"
    },
    {
      "source": "risk_critic",
      "target": "execution_realist",
      "contract": "CandidateDraft"
    },
    {
      "source": "execution_realist",
      "target": "finalize_candidate",
      "contract": "CandidateDraft"
    }
  ]
}
